# Appwrite (database + storage)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=mun_dashboard
APPWRITE_BUCKET_TOPIC_GUIDES=topic_guides
APPWRITE_BUCKET_INSTAGRAM_POSTS=instagram_posts

# Auth — main dashboard password (any length; padded internally)
SESSION_PASSWORD=change-me-to-a-long-random-string

# Sec-Gen password — gates the /executives panel (roster + minutes settings).
# If unset, the panel cannot be unlocked.
SECGEN_PASSWORD=

# Public base URL of the app — used to build links Apps Script / Meta fetch.
# Local: http://localhost:3000   Production: your Render URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Apps Script (see SETUP.md)
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXX/exec
CLASSROOM_COURSE_ID=123456789

# Instagram (optional — only needed for auto-post, see SETUP.md)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# OpenAI (optional — powers the AI half of the Topic Bank's "Suggest topics".
# If unset, suggestions fall back to the curated seed list silently.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
